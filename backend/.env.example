# Backend 配置示例
# 复制为 .env 后修改实际值

# 数据库
DATABASE_URL=sqlite:///./data/code_archaeology.db

# LLM 模式: openai / ollama / mock
LLM_MODE=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# 服务器
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 示例项目路径
SAMPLE_PROJECT_PATH=../sample-project